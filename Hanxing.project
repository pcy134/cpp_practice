#include<stdio.h>
int main()
{
	int a, b, c;
	int kase = 0;
	while (scanf_s("%d %d %d", &a, &b, &c) != EOF)
	{
		int d = 0;
		kase++;
		for (int i = 10; i <= 100;i++)
		{
			if (i % 3 == a && i % 5 == b && i % 7 == c)
			{
				printf("Case %d:%d",kase,i);
				d++;
				break;
			}
		}
		if (d == 0)
			printf("Case %d: No Answer",kase);
	}
	return 0;
}
