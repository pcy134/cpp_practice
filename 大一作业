#include<iostream>
#include<cstring>
using namespace std;
void screenoutput();
void front(char*);
void middle(char*);
void final(char*);
int main()
{
	char Str[100];
	int num = 0;
	cout << "请输入待处理字符串" << endl;
	cin >> Str;
	while (true)
	{
		screenoutput();
		cin >> num;
		if (num == 1)
		{
			front(Str);
			cout << Str << endl;
		}
		else if (num == 2)
		{
			middle(Str);
			cout << Str << endl;
		}
		else if (num == 3)
		{
			final(Str);
			cout << Str << endl;
		}
		else if (num == 4)
		{
			front(Str);
			middle(Str);
			final(Str);
			cout << Str << endl;
		}

		else if (num == 5)

		{

			cout << "程序退出中。。。" << endl;

			return 0;

		}

	}

	return 0;

}
void screenoutput()
{
	cout << "**************" << endl;
	cout << '*' << "1·去掉前面的*  *" << endl;
	cout << '*' << "2·去掉中间的*  *" << endl;
	cout << '*' << "3·去掉后面的*  *" << endl;
	cout << '*' << "4·去掉全面的*  *" << endl;
	cout << '*' << "5·退出       *" << endl;
	cout << "**************" << endl;
	cout << "请输入你的选择" << endl;
}
void front(char* Str)

{

	char* new1 = Str;

	while (*new1 == '*')

	{

		new1++;

	}

	while (*new1 != '\0')

	{

		*Str++ = *new1++;

	}

	*Str = '\0';

}
void middle(char* Str)
{
	if (strlen(Str) == 0) return;

	char* start = Str;
	char* end = Str + strlen(Str) - 1;

	// 找到第一个非 '*' 字符（前导）
	while (*start == '*' && *start != '\0') start++;
	// 找到最后一个非 '*' 字符（尾部）
	while (end >= start && *end == '*') end--;

	// 如果整个字符串都是 '*'，则清空
	if (start > end) {
		*Str = '\0';
		return;
	}

	char* read = start;
	char* write = Str;

	// 复制前导非 '*' 部分（其实 start 之前都是 '*'，不用复制）
	// 直接从中部开始处理：从 start 到 end，跳过 '*'
	while (read <= end) {
		if (*read != '*') {
			*write++ = *read;
		}
		read++;
	}
	*write = '\0';
}
void final(char* Str)
{
	char* new1 = Str;
	char* end = Str + strlen(Str) - 1;
	while (end >= Str && *end == '*')  // 注意边界：end >= Str
	{
		end--;
	}
	// 将有效字符前移（其实这里不需要移动，因为只删尾部）
	// 直接在 end+1 处加 '\0' 即可
	*(end + 1) = '\0';
}
